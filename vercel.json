{
    "functions": {
        "api/generate-protokoll.js": {
            "includeFiles": "mitnorm-logo.png"
        }
    },
    "cleanUrls": true,
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Frame-Options", "value": "DENY" },
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
            ]
        }
    ],
    "rewrites": [
        { "source": "/api/send-email", "destination": "/api/send-email" },
        { "source": "/api/brevo-webhook", "destination": "/api/brevo-webhook" },
        { "source": "/api/notify-berater", "destination": "/api/notify-berater" },
        { "source": "/api/create-berater-auth", "destination": "/api/create-berater-auth" },
        { "source": "/api/placetel-webhook", "destination": "/api/placetel-webhook" },
        { "source": "/api/upload-profil-bild", "destination": "/api/upload-profil-bild" },
        { "source": "/api/generate-protokoll", "destination": "/api/generate-protokoll" },
        { "source": "/api/invite-berater", "destination": "/api/invite-berater" },
        { "source": "/api/unsubscribe", "destination": "/api/unsubscribe" }
    ]
}
